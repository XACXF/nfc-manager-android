<?xml version="1.0" encoding="utf-8"?>
<!--
    Auto-backup rules
    This specifies which files to backup and which to exclude.
-->
<full-backup-content>
    <!-- Include shared preferences -->
    <include domain="sharedpref" path="." />
    
    <!-- Include database files -->
    <include domain="database" path="." />
    
    <!-- Include files in the files directory -->
    <include domain="file" path="." />
    
    <!-- Exclude cache directory -->
    <exclude domain="file" path="cache" />
    
    <!-- Exclude no_backup directory -->
    <exclude domain="file" path="no_backup" />
</full-backup-content>