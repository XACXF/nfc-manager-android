<?xml version="1.0" encoding="utf-8"?>
<!--
    Data extraction rules for Auto Backup for Apps feature.
    For more details see: https://developer.android.com/guide/topics/data/autobackup
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude cache and temporary files -->
        <exclude domain="file" path="cache/" />
        <exclude domain="file" path="temp/" />
        
        <!-- Exclude shared preferences that shouldn't be backed up -->
        <exclude domain="sharedpref" path="debug_prefs.xml" />
    </cloud-backup>
    <device-transfer>
        <!-- Include everything except cache and temp files -->
        <exclude domain="file" path="cache/" />
        <exclude domain="file" path="temp/" />
    </device-transfer>
</data-extraction-rules>